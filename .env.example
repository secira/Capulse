# Target Capital — Environment Variables
# Copy this file to .env for local development.
# In production (Railway / Replit), set these as platform secrets.

# ── Core ─────────────────────────────────────────────────────────────────────
SESSION_SECRET=                   # Required: random 32-byte secret for Flask sessions
DATABASE_URL=                     # Required: PostgreSQL connection string
ENVIRONMENT=development           # "development" | "production"

# ── Google SEO ───────────────────────────────────────────────────────────────
GOOGLE_GA4_ID=                    # GA4 Measurement ID (e.g. G-XXXXXXXXXX)
GOOGLE_GSC_VERIFY=                # Google Search Console HTML-tag verification code

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── AI Services ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                # Claude AI (primary AI engine)
PERPLEXITY_API_KEY=               # Perplexity Sonar (research co-pilot)

# ── Notifications ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=               # Telegram alert bot
TELEGRAM_CHAT_ID=                 # Telegram target chat/channel ID

# ── SMS / OTP (Twilio) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Email ────────────────────────────────────────────────────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# ── Payments (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Caching ──────────────────────────────────────────────────────────────────
REDIS_URL=                        # Optional: Redis connection string for rate limiting & caching
